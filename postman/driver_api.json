{
  "info": {
    "name": "Ridoo Driver API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Driver",
      "item": [
        {
          "name": "Go Online",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/driver/online"
          }
        },
        {
          "name": "Update Location",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/driver/location",
            "body": {
              "mode": "raw",
              "raw": "{\"latitude\":12.9716,\"longitude\":77.5946}"
            }
          }
        },
        {
          "name": "Accept Ride",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/rides/{{ride_id}}/accept"
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "base_url", "value": "http://localhost:8000/api/v1"},
    {"key": "token", "value": ""},
    {"key": "ride_id", "value": "1"}
  ]
}
